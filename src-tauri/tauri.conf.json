{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ClaudeDeck",
  "version": "0.2.10",
  "identifier": "com.claudedeck.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ClaudeDeck",
        "width": 920,
        "height": 750,
        "minWidth": 760,
        "minHeight": 390,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
